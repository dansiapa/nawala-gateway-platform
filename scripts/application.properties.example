# ============================================================
# Nawala Gateway Platform - Production Configuration
# ============================================================
# Copy this file to /opt/nawala/config/application.properties
# and fill in your actual values.
# ============================================================

# --- Database ---
spring.datasource.url=jdbc:mysql://${DB_HOST:localhost}:3306/nawala_db?useSSL=true&serverTimezone=UTC
spring.datasource.username=${DB_USERNAME}
spring.datasource.password=${DB_PASSWORD}
spring.jpa.hibernate.ddl-auto=update

# --- Redis ---
spring.data.redis.host=${REDIS_HOST:localhost}
spring.data.redis.port=${REDIS_PORT:6379}
spring.data.redis.password=${REDIS_PASSWORD:}

# --- Encryption ---
nawala.encryption.key=${NAWALA_ENCRYPTION_KEY}
nawala.gateway.jwt.secret=${NAWALA_JWT_SECRET}
nawala.gateway.payload-key=${NAWALA_PAYLOAD_KEY}
nawala.gateway.internal-secret=${NAWALA_INTERNAL_SECRET}

# --- Server ---
server.port=${SERVER_PORT:8080}
server.servlet.session.timeout=30m
server.servlet.session.cookie.http-only=true
server.servlet.session.cookie.secure=true
