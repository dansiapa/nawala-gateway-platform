<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>API Keys - Nawala</title>
    <link rel="stylesheet" th:href="@{/css/style.css}">
</head>
<body class="app-page">
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header"><div class="sidebar-brand"><svg width="32" height="32" viewBox="0 0 48 48" fill="none"><rect width="48" height="48" rx="12" fill="url(#grad1)"/><path d="M12 16h24M12 24h18M12 32h22" stroke="white" stroke-width="2.5" stroke-linecap="round"/><defs><linearGradient id="grad1" x1="0" y1="0" x2="48" y2="48"><stop stop-color="#667eea"/><stop offset="1" stop-color="#764ba2"/></linearGradient></defs></svg><span>Nawala</span></div></div>
        <nav class="sidebar-nav">
            <a href="/dashboard" class="nav-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg><span>Dashboard</span></a>
            <a href="/routes" class="nav-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V9z"/><polyline points="13 2 13 9 20 9"/></svg><span>API Routes</span></a>
            <a href="/api-keys" class="nav-item active"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 11-7.778 7.778 5.5 5.5 0 017.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg><span>API Keys</span></a>
            <a href="/profile" class="nav-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg><span>Profile</span></a>
        </nav>
        <div class="sidebar-footer"><form th:action="@{/logout}" method="post"><button type="submit" class="btn-icon" title="Sign out"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg></button></form></div>
    </aside>
    <main class="main-content">
        <header class="top-bar">
            <button class="mobile-menu-btn" onclick="toggleSidebar()"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg></button>
            <div class="page-title"><h1>API Keys</h1><p>Generate and manage authentication keys</p></div>
        </header>
        <div class="content-area">
            <div th:if="${success}" class="alert alert-success"><span th:text="${success}"></span></div>
            <div th:if="${rawKey}" class="alert alert-warning" style="flex-direction:column;align-items:flex-start">
                <strong>Your new API Key (shown only once):</strong>
                <code class="mono" style="margin-top:0.5rem;word-break:break-all;font-size:0.85rem" th:text="${rawKey}"></code>
                <small style="margin-top:0.5rem;opacity:0.8">Copy this key now. It will not be shown again.</small>
            </div>
            <div class="card" style="max-width:600px;margin-bottom:2rem">
                <div class="card-header"><h3>Generate New Key</h3></div>
                <div class="card-body">
                    <form th:action="@{/api-keys/generate}" method="post" class="profile-form">
                        <div class="input-row">
                            <div class="input-group">
                                <label for="name">Key Name</label>
                                <div class="input-wrapper"><input type="text" id="name" name="name" placeholder="e.g. Production Backend" required></div>
                            </div>
                            <div class="input-group">
                                <label for="expirationDays">Expires in (days)</label>
                                <div class="input-wrapper"><input type="number" id="expirationDays" name="expirationDays" placeholder="Leave blank for no expiry" min="1" max="365"></div>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary" style="margin-top:1rem"><span>Generate Key</span></button>
                    </form>
                </div>
            </div>
            <div class="card">
                <div class="card-header"><h3>Your Keys</h3></div>
                <div class="card-body" style="padding:0">
                    <table class="data-table">
                        <thead><tr><th>Name</th><th>Prefix</th><th>Status</th><th>Requests</th><th>Last Used</th><th>Actions</th></tr></thead>
                        <tbody>
                            <tr th:each="key : ${keys}">
                                <td th:text="${key.name}">Key</td>
                                <td class="mono" th:text="${key.prefix} + ''...''"  >nwl_abc...</td>
                                <td><span class="status-dot" th:classappend="${key.active && !key.expired} ? '' active'' : '' inactive''"></span><span th:text="${!key.active} ? ''Revoked'' : (${key.expired} ? ''Expired'' : ''Active'')">Active</span></td>
                                <td th:text="${key.requestCount}">0</td>
                                <td th:text="${key.lastUsedAt != null} ? ${#temporals.format(key.lastUsedAt, ''dd MMM yy HH:mm'')} : ''Never''">Never</td>
                                <td><form th:if="${key.active}" th:action="@{''/api-keys/'' + ${key.id} + ''/revoke''}" method="post" style="display:inline"><button type="submit" class="btn-sm btn-danger-sm" onclick="return confirm(''Revoke this key?'')">Revoke</button></form><span th:unless="${key.active}" class="text-muted">-</span></td>
                            </tr>
                            <tr th:if="${#lists.isEmpty(keys)}"><td colspan="6" class="empty-state" style="padding:2rem;text-align:center"><p>No API keys generated yet</p></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>
    <script th:src="@{/js/app.js}"></script>
</body>
</html>

